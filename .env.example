# Application
APP_NAME=AI Service
APP_VERSION=0.1.0
DEBUG=false
API_V1_PREFIX=/api/v1

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=ai_service

# JWT
JWT_SECRET_KEY=<GENERATE_STRONG_SECRET_KEY_HERE>
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=3

# Internal API
INTERNAL_API_KEY=<YOUR_INTERNAL_API_KEY>

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON=<YOUR_GOOGLE_SERVICE_ACCOUNT_JSON>
GOOGLE_SERVICE_ACCOUNT_EMAIL=<YOUR_GOOGLE_SERVICE_ACCOUNT_EMAIL>

# OpenAI
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
OPENAI_API_BASE=
MEETING_SUMMARY_QUEUE_NAME=meeting_summary_tasks
MEETING_SUMMARY_MAX_CONCURRENCY=2
MEETING_SUMMARY_MIN_BLOCKS_FOR_LIVE=2
MEETING_SUMMARY_MIN_NEW_BLOCKS=2

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_LEGACY_CHAT_DEPLOYMENT=

# Cloudinary
CLOUDINARY_CLOUD_NAME=<YOUR_CLOUDINARY_CLOUD_NAME>
CLOUDINARY_API_KEY=<YOUR_CLOUDINARY_API_KEY>
CLOUDINARY_API_SECRET=<YOUR_CLOUDINARY_API_SECRET>
MINIMAX_API_KEY=<YOUR_MINIMAX_API_KEY>
DEEPGRAM_API_KEY=<YOUR_DEEPGRAM_API_KEY>
MEETING_STT_CHANNELS=1
MEETING_STT_MULTICHANNEL=false
MEETING_STT_DIARIZE=true
MEETING_STT_ENDPOINTING_MS=400
MEETING_STT_UTTERANCE_END_MS=1000
MEETING_STT_KEEPALIVE_INTERVAL_SECONDS=5
